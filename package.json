{
  "name": "static-serve",
  "version": "0.1.0",
  "description": "A polished Bun static file server with readable directory listings.",
  "type": "module",
  "bin": {
    "static-serve": "./src/cli.ts"
  },
  "scripts": {
    "start": "bun src/cli.ts",
    "dev": "bun --watch src/cli.ts",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit"
  },
  "files": [
    "src"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "latest"
  }
}
